{
  "name": "oxlint-plugin-react-native",
  "version": "0.2.27",
  "description": "React Native specific linting rules for Oxlint",
  "keywords": [
    "oxlint",
    "oxlint-plugin",
    "oxlintplugin",
    "react",
    "react native",
    "react-native"
  ],
  "homepage": "https://github.com/huextrat/oxlint-plugin-react-native",
  "bugs": "https://github.com/huextrat/oxlint-plugin-react-native/issues",
  "license": "MIT",
  "author": "Hugo Extrat <extrat.h@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/huextrat/oxlint-plugin-react-native"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint --type-aware --type-check --report-unused-disable-directives",
    "lint:fix": "oxlint --type-aware --type-check --report-unused-disable-directives --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "release": "semantic-release"
  },
  "dependencies": {
    "@oxlint/plugins": "1.74.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.9.5",
    "commitlint": "^20.4.1",
    "jest": "30.4.2",
    "oxfmt": "^0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "semantic-release": "^25.0.3",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "oxlint": ">=1.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
